{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/layout-ddd/evaluation_report.schema.json",
  "title": "SceneHarnessEvaluationReport",
  "type": "object",
  "required": ["scene_id", "request_id", "evaluator_version", "overall_score", "reports", "notes"],
  "additionalProperties": true,
  "properties": {
    "scene_id": {"type": ["string", "null"]},
    "request_id": {"type": ["string", "null"]},
    "evaluator_version": {"const": "scene_harness_evaluator_v0"},
    "overall_score": {"type": "number"},
    "reports": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "generic_validity": {"type": "object"},
        "oor": {"type": "object"},
        "oar": {"type": "object"}
      }
    },
    "notes": {"type": "array", "items": {"type": "string"}}
  }
}
