{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/layout-ddd/generated_scene.schema.json",
  "title": "CanonicalGeneratedScene",
  "description": "Canonical generated_scene.json for the adapter-based scene harness. Uses objects, real asset jid references, asset_ref, and bbox/OBB asset_proxy geometry.",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": true,
  "required": ["scene_id", "request_id", "scene_type", "boundary", "objects"],
  "not": {"required": ["assets"]},
  "properties": {
    "scene_id": {"type": "string", "minLength": 1},
    "request_id": {"type": "string", "minLength": 1},
    "scene_type": {"type": "string", "minLength": 1},
    "boundary": {"$ref": "#/$defs/boundary"},
    "scene_height": {"type": "number", "exclusiveMinimum": 0},
    "objects": {"type": "array", "items": {"$ref": "#/$defs/object"}},
    "oor_relations": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "oar_relations": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "relations": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "metadata": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "boundary": {
      "type": "array",
      "minItems": 3,
      "items": {"type": "array", "minItems": 2, "items": {"type": "number"}}
    },
    "vec3": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "number"}},
    "positiveVec3": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "number", "exclusiveMinimum": 0}},
    "object": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "jid", "center", "rotation", "asset_ref", "asset_proxy", "metadata"],
      "not": {"required": ["asset_id"]},
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "jid": {"type": "string", "minLength": 1},
        "category": {"type": "string"},
        "retrieval_category": {"type": "string"},
        "desc": {"type": "string"},
        "short_desc": {"type": "string"},
        "size": {"$ref": "#/$defs/positiveVec3"},
        "center": {"$ref": "#/$defs/vec3"},
        "rotation": {"$ref": "#/$defs/vec3"},
        "asset_ref": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "source_db": {"type": "string"},
            "asset_key": {"type": "string"},
            "mesh_uri": {"type": ["string", "null"]},
            "pointcloud_uri": {"type": ["string", "null"]},
            "metadata_uri": {"type": ["string", "null"]}
          }
        },
        "asset_proxy": {
          "type": "object",
          "additionalProperties": true,
          "required": ["type", "bbox_size"],
          "properties": {
            "type": {"type": "string"},
            "bbox_center_local": {"$ref": "#/$defs/vec3"},
            "bbox_size": {"$ref": "#/$defs/positiveVec3"}
          }
        },
        "metadata": {"type": "object", "additionalProperties": true}
      },
      "anyOf": [
        {"required": ["size"]},
        {"properties": {"asset_proxy": {"required": ["bbox_size"]}}}
      ]
    }
  }
}
